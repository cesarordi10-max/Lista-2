#include <iostream>

using namespace std;

int main() {
    int m, n;
    cout << "Ingrese filas (m) y columnas (n): ";
    cin >> m >> n;

    int matriz[m][n];
    cout << "Ingrese los elementos de la matriz:\n";
    for(int i = 0; i < m; i++) {
        for(int j = 0; j < n; j++) {
            cin >> matriz[i][j];
        }
    }

    cout << "\nSuma de cada fila:\n";
    for(int i = 0; i < m; i++) {
        int sumaFila = 0;
        for(int j = 0; j < n; j++) {
            sumaFila += matriz[i][j];
        }
        cout << "Fila " << i + 1 << ": " << sumaFila << "\n";
    }

    return 0;
}
