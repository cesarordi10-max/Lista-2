#include <iostream>
#include <vector>

double sumaCuadradosVector(const std::vector<double>& vec) {
    double suma = 0.0;
    for (double componente : vec) {
        suma += componente * componente;
    }
    return suma;
}

int main() {
    // Ejemplo de uso
    std::vector<double> mi_vector = {2.0, 3.0, 4.0};
    
    double resultado = sumaCuadradosVector(mi_vector);
    
    std::cout << "La suma de los componentes al cuadrado es: " << resultado << std::endl;
    
    return 0;
}
