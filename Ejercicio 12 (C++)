#include <iostream>

using namespace std;

int main() {
    int n;
    cout << "Ingrese el tamaño n de la matriz cuadrada (n x n): ";
    cin >> n;

    int matriz[n][n];
    cout << "Ingrese los elementos de la matriz:\n";
    for(int i = 0; i < n; i++) {
        for(int j = 0; j < n; j++) {
            cin >> matriz[i][j];
        }
    }

    int sumaSecundaria = 0;
    for(int i = 0; i < n; i++) {
        sumaSecundaria += matriz[i][n - 1 - i]; // Elementos [0][n-1], [1][n-2], etc.
    }

    cout << "\nLa suma de la diagonal de derecha a izquierda es: " << sumaSecundaria << "\n";

    return 0;
}
